@model CarRentalManagementSystem_DBFirst.Models.Vehicle

@{
    ViewData["Title"] = "Yeni Araç Ekle";
}

<div class="container-fluid px-4">
    <h1 class="mt-4">Araç Yönetimi</h1>
    <ol class="breadcrumb mb-4">
        <li class="breadcrumb-item"><a href="/">Panel</a></li>
        <li class="breadcrumb-item"><a asp-action="Index">Araçlar</a></li>
        <li class="breadcrumb-item active">Yeni Araç</li>
    </ol>

    <div class="card mb-4 shadow">
        <div class="card-header bg-primary text-white">
            <i class="fas fa-car me-1"></i>
            Yeni Araç Kayıt Formu
        </div>
        <div class="card-body">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="Brand" class="form-label fw-bold">Marka</label>
                            <input asp-for="Brand" class="form-control" placeholder="Örn: Toyota" />
                            <span asp-validation-for="Brand" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="Model" class="form-label fw-bold">Model</label>
                            <input asp-for="Model" class="form-control" placeholder="Örn: Corolla" />
                            <span asp-validation-for="Model" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="Year" class="form-label fw-bold">Model Yılı</label>
                            <input asp-for="Year" type="number" class="form-control" placeholder="2023" />
                            <span asp-validation-for="Year" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="PlateNumber" class="form-label fw-bold">Plaka Numarası</label>
                            <input asp-for="PlateNumber" class="form-control" placeholder="34 ABC 123" />
                            <span asp-validation-for="PlateNumber" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="Color" class="form-label fw-bold">Renk</label>
                            <input asp-for="Color" class="form-control" placeholder="Örn: Beyaz" />
                            <span asp-validation-for="Color" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="Kilometer" class="form-label fw-bold">Kilometre</label>
                            <input asp-for="Kilometer" type="number" class="form-control" placeholder="0" />
                            <span asp-validation-for="Kilometer" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="DailyPrice" class="form-label fw-bold">Günlük Kiralama Ücreti</label>
                            <div class="input-group">
                                <span class="input-group-text">₺</span>
                                <input asp-for="DailyPrice" type="text" class="form-control" placeholder="0.00" />
                            </div>
                            <span asp-validation-for="DailyPrice" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="Status" class="form-label fw-bold">Aracın Durumu</label>
                            <select asp-for="Status" class="form-select">
                                <option value="true">Müsait</option>
                                <option value="false">Bakımda / Meşgul</option>
                            </select>
                            <span asp-validation-for="Status" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="mt-4 border-top pt-3 text-end">
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="fas fa-arrow-left"></i> Vazgeç ve Listeye Dön
                    </a>
                    <button type="submit" class="btn btn-success px-4">
                        <i class="fas fa-save"></i> Aracı Kaydet
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}