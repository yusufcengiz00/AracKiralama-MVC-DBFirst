@{
    ViewData["Title"] = "Yönetim Paneli";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid px-4 mt-2">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
        <span class="text-muted small">Araç kiralama sisteminizin güncel finansal ve operasyonel durumu.</span>
        <span class="badge bg-light text-dark border p-2">
            @DateTime.Now.ToString("dd MMMM yyyy")
        </span>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-xl-3 col-md-6">
            <div class="card shadow-sm border-start border-primary border-4 h-100">
                <div class="card-body">
                    <div class="text-muted small text-uppercase fw-bold">Toplam Araç</div>
                    <div class="fs-1 fw-bold text-primary mt-1">@ViewBag.TotalVehicles</div>
                </div>
                <div class="card-footer bg-transparent border-0 pt-0">
                    <a class="small text-decoration-none text-muted" asp-controller="Vehicle" asp-action="Index">
                        Araçları Listele <i class="fas fa-arrow-right ms-1"></i>
                    </a>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card shadow-sm border-start border-success border-4 h-100">
                <div class="card-body">
                    <div class="text-muted small text-uppercase fw-bold">Toplam Müşteri</div>
                    <div class="fs-1 fw-bold text-success mt-1">@ViewBag.TotalCustomers</div>
                </div>
                <div class="card-footer bg-transparent border-0 pt-0">
                    <a class="small text-decoration-none text-muted" asp-controller="Customer" asp-action="Index">
                        Müşterileri Göster <i class="fas fa-arrow-right ms-1"></i>
                    </a>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card shadow-sm border-start border-warning border-4 h-100">
                <div class="card-body">
                    <div class="text-muted small text-uppercase fw-bold">Aktif Kiralamalar</div>
                    <div class="fs-1 fw-bold text-warning mt-1">@ViewBag.TotalRentals</div>
                </div>
                <div class="card-footer bg-transparent border-0 pt-0">
                    <a class="small text-decoration-none text-muted fw-bold" asp-controller="Rental" asp-action="Index">
                        Sözleşmeleri İncele <i class="fas fa-arrow-right ms-1"></i>
                    </a>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card shadow-sm border-start border-danger border-4 h-100">
                <div class="card-body">
                    <div class="text-muted small text-uppercase fw-bold">Toplam Ciro</div>
                    <div class="fs-1 fw-bold text-danger mt-1">@string.Format("{0:C0}", ViewBag.TotalRevenue)</div>
                </div>
                <div class="card-footer bg-transparent border-0 pt-0">
                    <a class="small text-decoration-none text-muted" asp-controller="Payment" asp-action="Index">
                        Kasa Hareketleri <i class="fas fa-arrow-right ms-1"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="card mb-4 shadow-sm border-0 bg-light py-4 text-center">
                <div class="card-body py-3">
                    <h4 class="fw-bold text-dark mb-2">Performans Analizleri & Raporlama</h4>
                    <p class="text-muted mx-auto mb-4 small" style="max-width: 600px;">
                        Ödeme Bazlı Gelir Grafiğinizi tek bir ekrandan analiz edin.
                    </p>
                    <a class="btn btn-outline-dark px-4 btn-sm fw-bold" asp-controller="İstatistik" asp-action="Index">
                        Gelir Grafiğini Görüntüle
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>

    .card {
        border: 1px solid rgba(0,0,0,.08);
        border-radius: 6px;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

        .card:hover {
            transform: translateY(-2px);
            box-shadow: 0 .5rem 1rem rgba(0,0,0,.08) !important;
        }
</style>