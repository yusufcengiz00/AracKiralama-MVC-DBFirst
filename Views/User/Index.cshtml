@{
    Layout = "~/Views/Shared/_UserLayout.cshtml";
}

<div class="text-center mb-5">
    <h2 class="section-heading text-uppercase">Hizmetlerimiz</h2>
    <h3 class="section-subheading text-muted">
        AraçKiralamaNeKolay.com ile kiralama sürecinizin her adımında yanınızdayız.
    </h3>
</div>

<div class="row g-4">
    <div class="col-lg-4 col-md-6">
        <div class="service-box text-center h-100 p-4">
            <div class="service-icon mb-3">
                <i class="fas fa-car-side fa-2x"></i>
            </div>
            <h4 class="fw-bold">Geniş Araç Filosu</h4>
            <p class="text-muted mb-0">
                Ekonomik segmentten lüks sınıfa kadar geniş bir araç portföyü ile her ihtiyaca uygun seçenekler sunuyoruz.
            </p>
        </div>
    </div>

    <div class="col-lg-4 col-md-6">
        <div class="service-box text-center h-100 p-4">
            <div class="service-icon mb-3">
                <i class="fas fa-shield-alt fa-2x"></i>
            </div>
            <h4 class="fw-bold">Sigorta Güvencesi</h4>
            <p class="text-muted mb-0">
                Kiraladığınız her araç kasko ve trafik sigortası kapsamında olup, yolculuğunuz boyunca güvende olursunuz.
            </p>
        </div>
    </div>

    <div class="col-lg-4 col-md-6">
        <div class="service-box text-center h-100 p-4">
            <div class="service-icon mb-3">
                <i class="fas fa-headset fa-2x"></i>
            </div>
            <h4 class="fw-bold">7/24 Yol Yardımı</h4>
            <p class="text-muted mb-0">
                Yolculuğunuz sırasında oluşabilecek arıza veya kaza durumlarında 7 gün 24 saat destek ekibimiz yanınızda.
            </p>
        </div>
    </div>

    <div class="col-lg-4 col-md-6">
        <div class="service-box text-center h-100 p-4">
            <div class="service-icon mb-3">
                <i class="fas fa-calendar-check fa-2x"></i>
            </div>
            <h4 class="fw-bold">Online Rezervasyon</h4>
            <p class="text-muted mb-0">
                Dakikalar içinde online rezervasyon yaparak istediğiniz tarihte, istediğiniz aracı kolayca ayırtın.
            </p>
        </div>
    </div>

    <div class="col-lg-4 col-md-6">
        <div class="service-box text-center h-100 p-4">
            <div class="service-icon mb-3">
                <i class="fas fa-plane-arrival fa-2x"></i>
            </div>
            <h4 class="fw-bold">Havalimanı Teslim Noktası</h4>
            <p class="text-muted mb-0">
                Talep üzerine aracınızı havalimanında teslim alabilir, dönüşte de aynı noktaya teslim edebilirsiniz.
            </p>
        </div>
    </div>

    <div class="col-lg-4 col-md-6">
        <div class="service-box text-center h-100 p-4">
            <div class="service-icon mb-3">
                <i class="fas fa-tags fa-2x"></i>
            </div>
            <h4 class="fw-bold">Uygun Fiyat Garantisi</h4>
            <p class="text-muted mb-0">
                Şeffaf fiyatlandırma politikamızla gizli ücret yok; rezervasyon sırasında gördüğünüz fiyat, ödeyeceğiniz fiyattır.
            </p>
        </div>
    </div>
</div>

<div class="text-center mt-5">
    <a class="btn btn-primary btn-xl text-uppercase" href="#portfolio">Araçlarımızı İncele</a>
</div>