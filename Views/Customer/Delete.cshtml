@model CarRentalManagementSystem_DBFirst.Models.Customer

@{
    ViewData["Title"] = "Müşteri Silme Onayı";
}

<div class="container-fluid px-4">
    <h1 class="mt-4">Müşteri Yönetimi</h1>
    <ol class="breadcrumb mb-4">
        <li class="breadcrumb-item"><a href="/">Panel</a></li>
        <li class="breadcrumb-item"><a asp-action="Index">Müşteriler</a></li>
        <li class="breadcrumb-item active">Müşteri Sil</li>
    </ol>

    <div class="alert alert-danger d-flex align-items-center mb-4" role="alert">
        <i class="fas fa-exclamation-triangle me-2 fs-4"></i>
        <div>
            <strong>Kritik Uyarı!</strong> Bu müşteriyi silmek üzeresiniz. Eğer bu müşterinin geçmişe dönük kiralama sözleşmeleri (`Rentals`) mevcutsa, veritabanı bütünlüğü kuralları gereği SQL Server silme işlemini engelleyebilir.
        </div>
    </div>

    <div class="card mb-4 shadow">
        <div class="card-header bg-danger text-white fw-bold">
            <i class="fas fa-user-slash me-1"></i>
            Müşteri Hesabı Silme Onayı (ID: #@Model.CustomerId)
        </div>
        <div class="card-body">
            <h5 class="card-title mb-4 text-muted">Silinecek müşterinin sistem bilgileri:</h5>

            <div class="row bg-light p-3 rounded border">
                <div class="col-md-6 border-end">
                    <dl class="row mb-0">
                        <dt class="col-sm-4 text-secondary">Adı Soyadı:</dt>
                        <dd class="col-sm-8 fw-bold text-danger fs-5">@Model.FirstName @Model.LastName</dd>

                        <dt class="col-sm-4 text-secondary">Müşteri Numarası:</dt>
                        <dd class="col-sm-8 text-dark fw-bold">#@Model.CustomerId</dd>
                    </dl>
                </div>
                <div class="col-md-6 ps-4">
                    <dl class="row mb-0">
                        <dt class="col-sm-4 text-secondary">E-Posta:</dt>
                        <dd class="col-sm-8 text-primary">@Model.Email</dd>

                        <dt class="col-sm-4 text-secondary">Telefon:</dt>
                        <dd class="col-sm-8">@Model.Phone</dd>
                    </dl>
                </div>
            </div>

            <form asp-action="Delete" method="post" class="mt-4 text-end">
                <input type="hidden" asp-for="CustomerId" name="id" />

                <a asp-action="Index" class="btn btn-secondary me-2">
                    <i class="fas fa-arrow-left"></i> Hayır, Vazgeç ve Listeye Dön
                </a>
                <button type="submit" class="btn btn-danger px-4 fw-bold">
                    <i class="fas fa-trash-alt"></i> Evet, Bu Müşteriyi Tamamıyla Sil
                </button>
            </form>
        </div>
    </div>
</div>