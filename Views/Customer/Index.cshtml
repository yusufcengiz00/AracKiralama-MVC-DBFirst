@model IEnumerable<CarRentalManagementSystem_DBFirst.Models.Customer>

@{
    ViewData["Title"] = "Müşteri Listesi";
}

<div class="container-fluid px-4">
    <ol class="breadcrumb mb-4">
        <li class="breadcrumb-item"><a href="/">Panel</a></li>
        <li class="breadcrumb-item active">Müşteriler</li>
    </ol>

    <div class="card mb-4 shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center bg-dark text-white">
            <div>
                <i class="fas fa-users me-1"></i>
                Kayıtlı Müşteriler
            </div>
            <a asp-action="Create" class="btn btn-success btn-sm">
                <i class="fas fa-user-plus"></i> Yeni Müşteri Ekle
            </a>
        </div>

        <div class="card-body">
            <form asp-action="Index" method="get" class="mb-3">
                <div class="input-group" style="max-width: 450px;">
                    <input type="text" name="searchString" class="form-control"
                           placeholder="Müşteri adı veya soyadı ile ara..." value="@ViewBag.CurrentFilter" />
                    <button class="btn btn-primary" type="submit">
                        <i class="fas fa-search"></i> Ara
                    </button>
                    @if (!string.IsNullOrEmpty(ViewBag.CurrentFilter))
                    {
                        <a asp-action="Index" class="btn btn-outline-danger">Temizle</a>
                    }
                </div>
            </form>

            <div class="table-responsive">
                <table class="table table-bordered table-striped table-hover align-middle">
                    <thead class="table-secondary">
                        <tr>
                            <th>Müşteri ID</th>
                            <th>Adı Soyadı</th>
                            <th>E-Posta Adresi</th>
                            <th>Telefon Numarası</th>
                            <th class="text-center">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td>#@item.CustomerId</td>
                                    <td class="fw-bold">@item.FirstName @item.LastName</td>
                                    <td>
                                        <a href="mailto:@item.Email" class="text-decoration-none">
                                            <i class="far fa-envelope text-muted me-1"></i> @item.Email
                                        </a>
                                    </td>
                                    <td>
                                        <a href="tel:@item.Phone" class="text-decoration-none text-dark">
                                            <i class="fas fa-phone-alt text-muted me-1"></i> @item.Phone
                                        </a>
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group" role="group">
                                            <a asp-action="Edit" asp-route-id="@item.CustomerId" class="btn btn-warning btn-sm" title="Güncelle">
                                                <i class="fas fa-user-edit"></i>
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@item.CustomerId" class="btn btn-danger btn-sm" title="Sil">
                                                <i class="fas fa-user-slash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted py-4">Kayıtlı müşteri bulunamadı.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
<br />
<br />
<div class="card mb-4">
    <a asp-controller="Customer" asp-action="ExportToPdf" class="btn btn-danger">
        <i class="fa fa-file-pdf"></i> PDF Olarak İndir
    </a>
    <!-- YENİ: Excel Butonumuz -->
    <a asp-controller="Customer" asp-action="ExportToExcel" class="btn btn-success">
        <i class="fa fa-file-excel"></i> Excel Olarak İndir
    </a>
</div>