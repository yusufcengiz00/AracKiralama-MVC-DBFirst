@model CarRentalManagementSystem_DBFirst.Models.Payment

@{
    ViewData["Title"] = "Ödeme Kaydı Silme Onayı";
}

<div class="container-fluid px-4">
    <h1 class="mt-4">Kasa Yönetimi</h1>
    <ol class="breadcrumb mb-4">
        <li class="breadcrumb-item"><a href="/">Panel</a></li>
        <li class="breadcrumb-item"><a asp-action="Index">Ödemeler</a></li>
        <li class="breadcrumb-item active">Ödeme Kaydı Sil</li>
    </ol>

    <div class="alert alert-danger d-flex align-items-center mb-4" role="alert">
        <i class="fas fa-exclamation-triangle me-2 fs-4"></i>
        <div>
            <strong>Dikkat!</strong> Bu ödeme kaydını silmek üzeresiniz. Bu işlem doğrudan şirket kasa hareketlerini etkiler ve silinen mali veriler geri getirilemez.
        </div>
    </div>

    <div class="card mb-4 shadow">
        <div class="card-header bg-danger text-white fw-bold">
            <i class="fas fa-trash me-1"></i>
            Ödeme Kaydı Silme Onayı (Fatura ID: #@Model.PaymentId)
        </div>
        <div class="card-body">
            <h5 class="card-title mb-4 text-muted">Silinecek finansal işleme ait detaylar:</h5>

            <div class="row bg-light p-3 rounded border">
                <div class="col-md-6 border-end">
                    <dl class="row mb-0">
                        <dt class="col-sm-4 text-secondary">Müşteri Bilgisi:</dt>
                        <dd class="col-sm-8 fw-bold">
                            @(Model.Rental?.Customer != null ? $"{Model.Rental.Customer.FirstName} {Model.Rental.Customer.LastName}" : "Bilinmiyor")
                        </dd>

                        <dt class="col-sm-4 text-secondary">Araç / Plaka:</dt>
                        <dd class="col-sm-8 fw-bold text-primary">
                            @(Model.Rental?.Vehicle != null ? $"{Model.Rental.Vehicle.Brand} {Model.Rental.Vehicle.Model} ({Model.Rental.Vehicle.PlateNumber})" : "Bilinmiyor")
                        </dd>

                        <dt class="col-sm-4 text-secondary">Ödeme Türü:</dt>
                        <dd class="col-sm-8">
                            <span class="badge bg-secondary">@Model.PaymentMethod</span>
                        </dd>
                    </dl>
                </div>
                <div class="col-md-6 ps-4">
                    <dl class="row mb-0">
                        <dt class="col-sm-4 text-secondary">Ödeme Tarihi:</dt>
                        <dd class="col-sm-8">@Model.PaymentDate?.ToString("dd.MM.yyyy HH:mm")</dd>

                        <dt class="col-sm-4 text-secondary">Silinecek Tutar:</dt>
                        <dd class="col-sm-8 fw-bold text-danger fs-5">@string.Format("{0:C2}", Model.Amount)</dd>

                        <dt class="col-sm-4 text-secondary">İşlem Durumu:</dt>
                        <dd class="col-sm-8">
                            @if (Model.PaymentStatus == true)
                            {
                                <span class="badge bg-success">Alındı</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">İptal/İade</span>
                            }
                        </dd>
                    </dl>
                </div>
            </div>

            <form asp-action="Delete" method="post" class="mt-4 text-end">
                <input type="hidden" asp-for="PaymentId" name="id" />

                <a asp-action="Index" class="btn btn-secondary me-2">
                    <i class="fas fa-arrow-left"></i> Hayır, Vazgeç ve Listeye Dön
                </a>
                <button type="submit" class="btn btn-danger px-4 fw-bold">
                    <i class="fas fa-trash-alt"></i> Evet, Bu Ödeme Kaydını Sil
                </button>
            </form>
        </div>
    </div>
</div>