@model IEnumerable<CarRentalManagementSystem_DBFirst.Models.Rental>

@{
    ViewData["Title"] = "Kiralama İşlemleri";
}

<div class="container-fluid px-4">
    <ol class="breadcrumb mb-4">
        <li class="breadcrumb-item"><a href="/">Panel</a></li>
        <li class="breadcrumb-item active">Kiralamalar</li>
    </ol>

    <div class="card mb-4 shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center bg-dark text-white">
            <div>
                <i class="fas fa-key me-1"></i>
                Kiralama Kayıtları
            </div>
            <a asp-action="Create" class="btn btn-success btn-sm">
                <i class="fas fa-plus"></i> Yeni Kiralama Başlat
            </a>
        </div>

        <div class="card-body">
            <form asp-action="Index" method="get" class="mb-3">
                <div class="input-group" style="max-width: 450px;">
                    <input type="text" name="searchString" class="form-control"
                           placeholder="Müşteri adı veya plaka ile ara..." value="@ViewBag.CurrentFilter" />
                    <button class="btn btn-primary" type="submit">
                        <i class="fas fa-search"></i> Ara
                    </button>
                    @if (!string.IsNullOrEmpty(ViewBag.CurrentFilter))
                    {
                        <a asp-action="Index" class="btn btn-outline-danger">Temizle</a>
                    }
                </div>
            </form>

            <div class="table-responsive">
                <table class="table table-bordered table-striped table-hover align-middle">
                    <thead class="table-secondary">
                        <tr>
                            <th>Müşteri</th>
                            <th>Araç / Plaka</th>
                            <th>Başlangıç Tarihi</th>
                            <th>Bitiş Tarihi</th>
                            <th>Toplam Tutar</th>
                            <th>Durum</th>
                            <th class="text-center">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="fw-bold">
                                        @(item.Customer != null ? $"{item.Customer.FirstName} {item.Customer.LastName}" : "Bilinmeyen Müşteri")
                                    </td>
                                    <td>
                                        @if (item.Vehicle != null)
                                        {
                                            <span>@item.Vehicle.Brand @item.Vehicle.Model</span>
                                            <br />
                                            <span class="badge bg-secondary">@item.Vehicle.PlateNumber</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Araç Bilgisi Yok</span>
                                        }
                                    </td>
                                    <td>@item.StartDate?.ToString("dd.MM.yyyy")</td>
                                    <td>@item.EndDate?.ToString("dd.MM.yyyy")</td>
                                    <td class="fw-bold text-success">
                                        @string.Format("{0:C2}", item.TotalPrice)
                                    </td>
                                    <td>
                                        @switch (item.RentalStatus?.ToLower())
                                        {
                                            case "aktif":
                                            case "devam ediyor":
                                                <span class="badge bg-primary">Aktif</span>
                                                break;
                                            case "tamamlandı":
                                            case "bitti":
                                                <span class="badge bg-success">Tamamlandı</span>
                                                break;
                                            case "iptal":
                                            case "iptal edildi":
                                                <span class="badge bg-danger">İptal Edildi</span>
                                                break;
                                            default:
                                                <span class="badge bg-warning text-dark">@item.RentalStatus</span>
                                                break;
                                        }
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group" role="group">
                                            <a asp-action="Edit" asp-route-id="@item.RentalId" class="btn btn-warning btn-sm" title="Güncelle">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@item.RentalId" class="btn btn-danger btn-sm" title="Sil">
                                                <i class="fas fa-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center text-muted py-4">Kiralama kaydı bulunamadı.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>